// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run zed: open default settings from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
 "cli_default_open_behavior": "existing_window",
 "agent": {
  "default_model": {
   "provider": "openai",
   "model": "phi-4-mini",
   "enable_thinking": false
  },
  "favorite_models": [],
  "model_parameters": []
 },
 "agent_servers": {
  "your_agent": {
   "type": "custom",
   "command": "path_to_executable"
  }
 },
 "lsp": {
  "vtsls": {
   "settings": {
    "typescript": {
     "updateImportsOnFileMove": {
      "enabled": "always"
     }
    },
    "javascript": {
     "updateImportsOnFileMove": {
      "enabled": "always"
     }
    }
   },
   "enable_lsp_tasks": true
  }
 },
 "terminal": {
  "shell": {
   "program": "\"C:\\Program Files\\Git\\bin\\bash.exe\""
  }
 },
 "autosave": "on_focus_change",
 "icon_theme": {
  "mode": "system",
  "light": "Zed (Default)",
  "dark": "Warm Charmed Icons"
 },
 "ui_font_size": 16,
 "buffer_font_size": 15,
 "theme": {
  "mode": "system",
  "light": "Ayu Light",
  "dark": "Aura Dark"
 },
 "theme_overrides": {
  "Aura Dark": {
   "border.variant": "#15141D",
   "border": "#15141D",
   "title_bar.background": "#15141D",
   "panel.background": "#15141D",
   "panel.focused_border": "#4E466E",
   "players": [
    {
     "cursor": "#bd9dff"
    }
   ],
   "syntax": {
    "comment": {
     "font_style": "italic" // Inline comments
    },
    "comment.doc": {
     "font_style": "italic" /* Document comments */
    }
   }
  }
 },
 "title_bar": {
  "show_onboarding_banner": false,
  "show_project_items": false
 },
 "formatter": "language_server",
 "languages": {
  "CSS": {
   "formatter": {
    "language_server": {
     "name": "biome"
    }
   }
  },
  "HTML": {
   "formatter": {
    "language_server": {
     "name": "biome"
    }
   }
  },
  "JSON": {
   "formatter": {
    "language_server": {
     "name": "biome"
    }
   }
  },
  "JSONC": {
   "formatter": {
    "language_server": {
     "name": "biome"
    }
   }
  },
  "JavaScript": {
   "formatter": {
    "language_server": {
     "name": "biome"
    }
   }
  },
  "TSX": {
   "formatter": {
    "language_server": {
     "name": "biome"
    }
   }
  },
  "TypeScript": {
   "formatter": {
    "language_server": {
     "name": "biome"
    }
   }
  }
 },
 "language_models": {
  "openai": {
   "api_url": "http://localhost:8080/v1",
   "available_models": [
    {
     "name": "phi-4-mini",
     "display_name": "Phi-4 Mini (Local)",
     "max_tokens": 4096
    }
   ]
  }
 }
}
